# ── Neon (copy from neon.tech dashboard → Connection String) ──────────────
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Telegram ──────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram
# 2. Send /newbot → follow prompts → copy the token below
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3. Each admin opens a chat with your bot and sends /start
# 4. Visit: https://api.telegram.org/bot<TOKEN>/getUpdates
# 5. Copy the "chat"."id" values (comma-separated for multiple people)
TELEGRAM_CHAT_IDS=123456789,987654321

# ── Resend (resend.com → API Keys) ────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Hostinger IMAP (for inbox sync) ──────────────────────────────────────
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_USER=info@claracareteam.com
IMAP_PASS=your_email_password_here

# ── Admin dashboard ───────────────────────────────────────────────────────
# Change this to whatever PIN Jessica and Kevin will use
ADMIN_PIN=clara2025
# Random secret string (openssl rand -base64 32)
ADMIN_SECRET=change-me-to-a-random-32-char-string

# ── Cron security (optional, for /api/admin/sync-inbox auto-run) ─────────
CRON_SECRET=another-random-secret
